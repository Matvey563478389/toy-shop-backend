# Скопируйте в .env в корне репозитория для docker compose -f docker-compose.prod.yml

HTTP_PORT=80

DATABASE_NAME=toyshop
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=смените_на_случайную_строку

JWT_SECRET=смените_на_длинную_случайную_строку

# Если фронт и API за одним доменом через этот compose — можно оставить пустым.
# Если открываете API отдельно или тестируете с другого origin — укажите через запятую:
# CORS_ORIGIN=https://ваш-домен.ru,https://www.ваш-домен.ru
CORS_ORIGIN=

ADMIN_EMAIL=admin@toyshop.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=admin
